---
import '../styles/global.css';
import { getLangFromUrl, useTranslations } from '../i18n/ui';
import ChatWidget from '../components/ChatWidget';

interface Props {
	title: string;
}

const { title } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Uapa Empleos Platform" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
  <body class="bg-gray-50 text-gray-900 min-h-screen flex flex-col">
    {/* Official Navy Blue Header */}
    <header class="bg-uapa-blue shadow-md border-b-4 border-uapa-orange">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex justify-between items-center">
        
        {/* Official UAPA Logo (White version for dark background) */}
        <a href={lang === 'es' ? '/' : `/${lang}/`} class="flex items-center">
          <img 
            src="https://www.uapa.edu.do/wp-content/uploads/2022/06/Logo-blanco-UAPA.png" 
            alt="UAPA Logo" 
            class="h-12 w-auto object-contain"
            onError="this.onerror=null; this.src='https://upload.wikimedia.org/wikipedia/commons/thumb/c/c5/Logo_UAPA.png/320px-Logo_UAPA.png';"
          />
        </a>

        <nav class="space-x-4 font-medium flex items-center">
          <a href={lang === 'es' ? '/jobs' : `/${lang}/jobs`} class="text-white hover:text-uapa-orange transition-colors">{t('nav.jobs')}</a>
          
          <div id="unauth-nav" class="space-x-4 flex items-center">
            <a href={lang === 'es' ? '/login' : `/${lang}/login`} class="text-white hover:text-uapa-orange transition-colors">{t('nav.login')}</a>
            <a href={lang === 'es' ? '/signup' : `/${lang}/signup`} class="px-5 py-2.5 bg-uapa-orange text-white rounded-lg hover:bg-orange-600 shadow-sm transition-all ml-2">{t('nav.signup')}</a>
          </div>

          <div id="auth-nav" class="hidden items-center relative">
            <button id="profile-dropdown-btn" class="flex items-center space-x-2 focus:outline-none group">
              <div class="w-10 h-10 rounded-full border-2 border-transparent group-hover:border-uapa-orange overflow-hidden bg-white/10 flex items-center justify-center transition-colors">
                <img id="nav-avatar" src="" class="w-full h-full object-cover hidden" alt="Avatar"/>
                <svg id="nav-avatar-placeholder" class="w-6 h-6 text-uapa-sand" fill="currentColor" viewBox="0 0 24 24"><path d="M24 20.993V24H0v-2.996A14.977 14.977 0 0112.004 15c4.904 0 9.26 2.354 11.996 5.993zM16.002 8.999a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
              </div>
              <svg class="w-4 h-4 text-white group-hover:text-uapa-orange transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M19 9l-7 7-7-7"></path></svg>
            </button>
            
            <div id="profile-dropdown-menu" class="hidden absolute right-0 top-12 w-56 bg-white rounded-xl shadow-xl py-2 border border-gray-100 z-50 flex flex-col">
              <div class="px-4 py-3 border-b border-gray-50 bg-gray-50/50">
                <span class="block text-sm font-bold text-uapa-blue truncate" id="user-name"></span>
              </div>
              <a href={lang === 'es' ? '/network' : `/${lang}/network`} class="px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 flex items-center">
                <svg class="w-4 h-4 mr-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                {lang === 'es' ? 'Red / Network' : 'Network'}
              </a>
              <a href={lang === 'es' ? '/profile' : `/${lang}/profile`} class="px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 flex items-center">
                <svg class="w-4 h-4 mr-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                {lang === 'es' ? 'Mi Perfil' : 'My Profile'}
              </a>
              <button id="logout-btn" class="w-full text-left px-4 py-2.5 text-sm text-red-600 hover:bg-red-50 flex items-center border-t border-gray-50 mt-1">
                <svg class="w-4 h-4 mr-3 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                {lang === 'es' ? 'Salir' : 'Sign out'}
              </button>
            </div>
          </div>
        </nav>
      </div>
    </header>

    <main class="flex-grow">
      <slot />
    </main>

    <ChatWidget lang={lang} client:load />

    <footer class="bg-uapa-blue text-gray-300 border-t-4 border-uapa-sand mt-auto">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 text-center">
        &copy; {new Date().getFullYear()} {t('footer.rights')}
      </div>
    </footer>

    <script>
      import { supabase } from '../lib/supabase';

      async function setupAuthUI() {
        const unauthNav = document.getElementById('unauth-nav');
        const authNav = document.getElementById('auth-nav');
        const userNameEl = document.getElementById('user-name');
        const logoutBtn = document.getElementById('logout-btn');

        const { data: { session } } = await supabase.auth.getSession();

        if (session && session.user) {
          if (unauthNav) unauthNav.style.display = 'none';
          if (authNav) {
            authNav.classList.remove('hidden');
            authNav.classList.add('flex');
          }
          
          let name = session.user.user_metadata?.full_name;
          let avatarUrl = null;

          const { data } = await supabase.from('profiles').select('full_name, avatar_url').eq('id', session.user.id).single();
          if (data) {
            if (!name) name = data.full_name;
            avatarUrl = data.avatar_url;
          }

          if (userNameEl) {
            userNameEl.textContent = name || session.user.email?.split('@')[0] || 'Usuario';
          }

          const navAvatar = document.getElementById('nav-avatar');
          const navPlaceholder = document.getElementById('nav-avatar-placeholder');
          if (avatarUrl && navAvatar && navPlaceholder) {
            navAvatar.src = avatarUrl;
            navAvatar.classList.remove('hidden');
            navPlaceholder.classList.add('hidden');
          }
        }

        // Dropdown toggle logic
        const dropdownBtn = document.getElementById('profile-dropdown-btn');
        const dropdownMenu = document.getElementById('profile-dropdown-menu');
        
        if (dropdownBtn && dropdownMenu) {
           dropdownBtn.addEventListener('click', (e) => {
              e.stopPropagation();
              dropdownMenu.classList.toggle('hidden');
           });
           document.addEventListener('click', (e) => {
              if (!dropdownMenu.contains(e.target) && !dropdownBtn.contains(e.target)) {
                 dropdownMenu.classList.add('hidden');
              }
           });
        }

        if (logoutBtn) {
          logoutBtn.addEventListener('click', async () => {
            await supabase.auth.signOut();
            window.location.reload();
          });
        }
      }

      setupAuthUI();
    </script>
  </body>
</html>
