---
import Layout from '../../layouts/Layout.astro';
import InteractiveAppStatus from '../../components/InteractiveAppStatus';

// In a real app, this page would fetch the application details securely
// using the ID from the URL. Here we provide a mock/demo interface.
const { id } = Astro.params;
---

<Layout title="Application Status - JobBoard">
  <div class="px-4 py-12 max-w-4xl mx-auto">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-extrabold text-gray-900">Application Status Portal</h1>
      <p class="mt-2 text-gray-500">Tracking application ID: <span class="font-mono text-xs bg-gray-100 px-2 py-1 rounded">{id}</span></p>
    </div>

    {/* The Real-Time React Island */}
    <InteractiveAppStatus applicationId={id as string} initialStatus="pending" client:only="react" />
  </div>
</Layout>
