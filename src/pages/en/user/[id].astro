---
import Layout from '../../../layouts/Layout.astro';
import { supabase } from '../../../lib/supabase';
import { getLangFromUrl, useTranslations } from '../../../i18n/ui';
import ConnectButton from '../../../components/ConnectButton';

export const prerender = false;

const { id } = Astro.params;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { data: profile, error } = await supabase
  .from('profiles')
  .select('*')
  .eq('id', id)
  .single();

if (error || !profile) {
  return Astro.redirect('/404');
}

const isTalent = profile.role === 'talent';
---

<Layout title={`${profile.full_name || 'Profile'} - Uapa Empleos`}>
  <div class="bg-gray-100 min-h-screen pb-20">
    <div class="max-w-4xl mx-auto pt-8 px-4 sm:px-6 lg:px-8">
      
      {/* Main Profile Card */}
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden relative mb-6">
        <div class="h-48 bg-gradient-to-r from-uapa-blue to-blue-800 w-full relative">
          <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] mix-blend-overlay"></div>
        </div>
        
        <div class="px-8 pb-8">
          <div class="relative -mt-20 sm:-mt-24 mb-4 flex justify-between items-end">
            <div class="w-32 h-32 sm:w-40 sm:h-40 bg-white rounded-full p-1 shadow-lg relative z-10">
              <div class="w-full h-full rounded-full bg-gray-100 border-2 border-gray-50 flex items-center justify-center overflow-hidden">
                {profile.avatar_url ? (
                  <img src={profile.avatar_url} alt={profile.full_name} class="w-full h-full object-cover" />
                ) : (
                  <svg class="w-20 h-20 text-gray-300" fill="currentColor" viewBox="0 0 24 24"><path d="M24 20.993V24H0v-2.996A14.977 14.977 0 0112.004 15c4.904 0 9.26 2.354 11.996 5.993zM16.002 8.999a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
                )}
              </div>
            </div>
            
            <div class="flex gap-3 relative z-10 mb-2 items-center">
               <ConnectButton client:load targetUserId={profile.id} />
               <button class="bg-white hover:bg-gray-50 border-2 border-uapa-orange text-uapa-orange font-bold py-2 px-6 rounded-full shadow-sm transition-colors flex items-center focus:outline-none focus:ring-4 focus:ring-orange-100">
                 <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
                 Message
               </button>
            </div>
          </div>
          
          <div>
            <h1 class="text-3xl font-black text-gray-900 tracking-tight">{profile.full_name || 'Anonymous User'}</h1>
            <p class="text-xl text-gray-800 font-medium mt-1">{profile.headline || (isTalent ? 'Looking for opportunities' : 'Network Recruiter')}</p>
            
            <div class="flex flex-wrap items-center mt-3 text-sm text-gray-500 gap-y-2 gap-x-4">
              {profile.location && (
                <span class="flex items-center">
                  <svg class="w-4 h-4 mr-1 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                  {profile.location}
                </span>
              )}
              <span class="flex items-center text-uapa-blue font-semibold bg-blue-50 px-2 py-1 rounded-md">
                {isTalent ? 'Talent' : 'Recruiter'}
              </span>
            </div>
          </div>
        </div>
      </div>

      {/* About Section */}
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8 mb-6">
        <h2 class="text-xl font-bold text-gray-900 mb-4 flex items-center">
           About
        </h2>
        {profile.bio ? (
          <p class="text-gray-700 leading-relaxed whitespace-pre-wrap">{profile.bio}</p>
        ) : (
          <p class="text-gray-400 italic">This user hasn't added a bio yet.</p>
        )}
      </div>

      {/* Skills & Languages Grid */}
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {/* Skills Section */}
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
          <h2 class="text-lg font-bold text-gray-900 mb-4">Skills</h2>
          {profile.skills && profile.skills.length > 0 ? (
            <div class="flex flex-wrap gap-2">
              {profile.skills.map((skill: string) => (
                <span class="bg-blue-50 text-uapa-blue border border-blue-200 font-medium px-3 py-1.5 rounded-lg text-sm">
                  {skill}
                </span>
              ))}
            </div>
          ) : (
            <p class="text-gray-400 text-sm">No skills listed.</p>
          )}
        </div>

        {/* Languages Section */}
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
          <h2 class="text-lg font-bold text-gray-900 mb-4">Languages</h2>
          {profile.languages && profile.languages.length > 0 ? (
            <div class="flex flex-wrap gap-2">
              {profile.languages.map((lang: string) => (
                <span class="bg-gray-50 text-gray-700 border border-gray-200 font-medium px-3 py-1.5 rounded-lg text-sm">
                   {lang}
                </span>
              ))}
            </div>
          ) : (
            <p class="text-gray-400 text-sm">No languages listed.</p>
          )}
        </div>
      </div>

    </div>
  </div>
</Layout>
