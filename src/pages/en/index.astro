---
import Layout from '../../layouts/Layout.astro';
import SearchBar from '../../components/SearchBar';
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../../i18n/ui';

const jobs = await getCollection('jobs');
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title="Uapa Empleos">
  <div class="bg-white border-b-2 border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-28 text-center">
      <h1 class="text-5xl md:text-6xl font-black tracking-tight mb-6 text-uapa-blue">
        {t('hero.title')}
      </h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto font-medium">
        {t('hero.subtitle')}
      </p>
      
      {/* Searchbar wrapper for extra breathing room */}
      <div class="mt-10">
        <SearchBar client:load lang={lang} />
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="flex items-center justify-between mb-10">
      <h2 class="text-3xl font-bold text-gray-900">{t('jobs.latest')}</h2>
      <div class="h-1 w-20 bg-uapa-orange rounded"></div>
    </div>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {jobs.map(job => (
        <a href={lang === 'es' ? `/jobs/${job.slug}` : `/${lang}/jobs/${job.slug}`} class="block group">
          <div class="bg-white border-2 border-transparent rounded-2xl p-6 shadow-sm hover:border-uapa-sand hover:shadow-xl transition-all duration-300">
            <h3 class="text-xl font-bold text-gray-900 group-hover:text-uapa-blue transition-colors">
              {job.data.title}
            </h3>
            <p class="text-gray-500 font-medium mt-2">{job.data.company}</p>
            <div class="mt-5 pt-4 border-t border-gray-100 flex items-center text-sm text-gray-500 space-x-4">
              <span class="flex items-center text-uapa-orange font-semibold">
                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                {job.data.location}
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>
