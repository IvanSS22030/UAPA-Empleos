---
import Layout from '../../layouts/Layout.astro';
import GlobalJobSearch from '../../components/GlobalJobSearch';
import { getLangFromUrl, useTranslations } from '../../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={`Buscar Empleos - Uapa Empleos`}>
  <div class="bg-uapa-blue/5 border-b-2 border-uapa-blue/10 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-extrabold text-uapa-blue mb-4">Descubre Tu Próximo Empleo</h1>
      <p class="text-xl text-gray-600 font-medium">Filtra miles de oportunidades por modalidad, ubicación y más.</p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
    <GlobalJobSearch lang={lang} client:load />
  </div>
</Layout>
