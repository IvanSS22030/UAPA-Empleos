---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ApplicationForm from '../../components/ApplicationForm';

export async function getStaticPaths() {
  const jobEntries = await getCollection('jobs');
  return jobEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={`${entry.data.title} - JobBoard`}>
  {/* data-pagefind-body is standard for pagefind indexing */}
  <article class="max-w-4xl mx-auto px-4 py-16" data-pagefind-body>
    <header class="mb-12 border-b pb-8">
      <h1 class="text-4xl font-extrabold text-gray-900 mb-4">{entry.data.title}</h1>
      <div class="flex text-gray-500 space-x-6 text-lg">
        <span class="font-medium text-indigo-600">{entry.data.company}</span>
        <span>&bull;</span>
        <span>{entry.data.location}</span>
        <span>&bull;</span>
        <span>{new Date(entry.data.date_posted).toLocaleDateString()}</span>
      </div>
    </header>

    <div class="prose prose-indigo prose-lg max-w-none text-gray-700">
      <Content />
    </div>

    <div class="mt-16 bg-white rounded-2xl p-8 border border-gray-100 shadow-sm text-center">
      <h3 class="text-2xl font-bold text-gray-900 mb-2">Ready to Apply?</h3>
      <p class="text-gray-500 mb-8">Complete the application form below. Your resume will be securely uploaded.</p>
      {/* Interactive Application Form React Island */}
      <ApplicationForm jobId={entry.id} client:load />
    </div>
  </article>
</Layout>
